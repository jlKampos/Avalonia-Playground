<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:vm="using:MyAvalonia.ViewModels"
			 x:Name="SeismologyPage"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:mapsui="clr-namespace:Mapsui.UI.Avalonia;assembly=Mapsui.UI.Avalonia"
			 xmlns:pg="clr-namespace:MyAvalonia.Views.Progress"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="MyAvalonia.Views.SeismologyPageView"
			 x:DataType="vm:SeismologyPageViewModel">

	<Grid RowDefinitions="100,*">
		<!-- Header with DatePicker -->
		<Border Grid.Row="0" Background="{DynamicResource PanelGradient}" Padding="20">
			<StackPanel Orientation="Horizontal" Spacing="20">
				<TextBlock Text="Seismic Activity" Foreground="White" FontSize="20" VerticalAlignment="Center"/>

				<CalendarDatePicker SelectedDate="{Binding SelectedDate}"
									DisplayDateStart="{Binding MinDate}"
									DisplayDateEnd="{Binding MaxDate}"
									HorizontalAlignment="Left"
									Watermark="Select a date"
									Width="250" />
			</StackPanel>
		</Border>
		<!-- Progress Overlay -->
		<Border  Padding="0" Grid.Row="1" IsVisible="{Binding ProgressControl.IsVisible}" ZIndex="10">
			<pg:ProgressControl DataContext="{Binding ProgressControl}" />
		</Border>

		<!-- Map Body -->
		<Border Padding="0" IsVisible="{Binding !ProgressControl.IsVisible}" Grid.Row="1">
			<mapsui:MapControl x:Name="MyMapControl" />
		</Border>
	</Grid>
</UserControl>