<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:vm="using:OmniWatch.ViewModels"
			 xmlns:conv="clr-namespace:OmniWatch.Helpers"
			 xmlns:mapsui="clr-namespace:Mapsui.UI.Avalonia;assembly=Mapsui.UI.Avalonia"
			 xmlns:pg="clr-namespace:OmniWatch.Views.Progress"
			 x:DataType="vm:NoaaPageViewModel"
			 x:Class="OmniWatch.Views.NoaaPageView">
	<UserControl.Resources>

		<DataTemplate x:Key="LightIconTemplate">
			<Label FontFamily="{DynamicResource PhosphorFill}"
				   Classes="icon"
				   Content="&#xE472;"
				   FontSize="11"
				   FontWeight="Bold"
				   Foreground="#FF191000"
				   VerticalContentAlignment="Center"
				   HorizontalContentAlignment="Center"/>
		</DataTemplate>

		<DataTemplate x:Key="DarkIconTemplate">
			<Label FontFamily="{DynamicResource PhosphorFill}"
				   Classes="icon"
				   Content="&#xE330;"
				   FontSize="11"
				   FontWeight="Bold"
				   Foreground="#FF191000"
				   VerticalContentAlignment="Center"
				   HorizontalContentAlignment="Center"/>
		</DataTemplate>

	</UserControl.Resources>


	<Grid RowDefinitions="100,*">
		<Border Grid.Row="0"
				Background="{DynamicResource ResourceKey=PanelGradient}"
				Padding="20">

			<Grid ColumnDefinitions="Auto,*,Auto"
				  VerticalAlignment="Center">

				<!-- TITLE -->
				<TextBlock Text="NOAA"
						   Foreground="White"
						   FontSize="20"
						   VerticalAlignment="Center"/>

				<!-- RIGHT SIDE -->
				<StackPanel Grid.Column="2"
							Orientation="Horizontal"
							HorizontalAlignment="Right"
							VerticalAlignment="Center"
							Spacing="10">

					<ComboBox ItemsSource="{Binding Years}"
							  SelectedItem="{Binding SelectedYear}"
							  Width="120"
							  VerticalAlignment="Center"/>

					<ComboBox IsEnabled="{Binding !ProgressControl.IsVisible}"
							  ItemsSource="{Binding Hurricanes}"
							  DisplayMemberBinding="{Binding Name}"
							  SelectedItem="{Binding SelectedHurricane}"
							  Width="150"
							  VerticalAlignment="Center"/>
				</StackPanel>

			</Grid>
		</Border>

		<!-- Progress Overlay -->
		<Border  Padding="0" Grid.Row="1" IsVisible="{Binding ProgressControl.IsVisible}" ZIndex="10">
			<pg:ProgressControl DataContext="{Binding ProgressControl}" />
		</Border>

		<!-- Map Body -->
		<Border Grid.Row="1"
				Padding="0" IsVisible="{Binding !ProgressControl.IsVisible}"
				Background="{DynamicResource ResourceKey=PanelGradient}">
			<Grid>
				<!-- Mapa -->
				<mapsui:MapControl x:Name="MyMapControl"
								   Background="Transparent"
								   HorizontalAlignment="Stretch"
								   VerticalAlignment="Stretch"
								   Margin="0" />

				<Grid HorizontalAlignment="Left"
					  VerticalAlignment="Top"
					  Margin="10"
					  RowSpacing="5">

					<Border Background="#BFFFA500"
							CornerRadius="4"
							Padding="7"
							Margin="5,0,0,0"
							VerticalAlignment="Center"
							IsVisible="{Binding AnyActiveStorms}">
						<TextBlock Text="{Binding ActiveStormsMessage}"
								   Foreground="#FF191000"
								   FontSize="10"
								   FontWeight="Bold"
								   TextWrapping="Wrap"/>
					</Border>
				</Grid>

				<Grid RowDefinitions="Auto,*" HorizontalAlignment="Right"
					  VerticalAlignment="Top"
					  Margin="10"
					  RowSpacing="5">
					<!-- Reanimate -->
					<Border Grid.Row="0"
							Background="#BF8FAA00"
							CornerRadius="4"
							Padding="6">

						<Grid  ColumnDefinitions="Auto,*"
							   ColumnSpacing="10"
							   HorizontalAlignment="Stretch"
							   VerticalAlignment="Center">

							<TextBlock Text="Reanimate"
									   FontSize="11"
									   FontWeight="Bold"
									   VerticalAlignment="Center"
									   Margin="0,0,10,0"
									   Foreground="#FF191000"/>

							<ToggleSwitch Grid.Column="1"
										  Height="30"
										  Width="110"
										  IsChecked="{Binding Reanimate}"
										  HorizontalAlignment="Center"
										  VerticalAlignment="Center">

								<ToggleSwitch.OnContentTemplate>
									<DataTemplate>
										<TextBlock Text="Yes"
												   FontSize="11"
												   FontWeight="Bold"
												   HorizontalAlignment="Center"
												   VerticalAlignment="Center"
												   Foreground="#FF191000"/>
									</DataTemplate>
								</ToggleSwitch.OnContentTemplate>

								<ToggleSwitch.OffContentTemplate>
									<DataTemplate>
										<TextBlock Text="No"
												   FontSize="11"
												   FontWeight="Bold"
												   HorizontalAlignment="Center"
												   VerticalAlignment="Center"
												   Foreground="#FF191000"/>
									</DataTemplate>
								</ToggleSwitch.OffContentTemplate>

							</ToggleSwitch>

						</Grid>

					</Border>

					<!-- Theme -->
					<Border Grid.Row="1"
							Background="#BF8FAA00"
							CornerRadius="4"
							Padding="6">

						<Grid  ColumnDefinitions="Auto,*"
							   ColumnSpacing="10"
							   HorizontalAlignment="Stretch"
							   VerticalAlignment="Center">

							<TextBlock Text="Theme"
									   FontSize="11"
									   FontWeight="Bold"
									   VerticalAlignment="Center"
									   Margin="0,0,10,0"
									   Foreground="#FF191000"/>

							<ToggleSwitch Grid.Column="1"
										  Width="110"
										  IsChecked="{Binding IsDarkTheme, Mode=TwoWay}"
										  HorizontalAlignment="Center"
										  VerticalAlignment="Center"
										  OffContentTemplate="{StaticResource LightIconTemplate}"
										  OnContentTemplate="{StaticResource DarkIconTemplate}" />
						</Grid>
					</Border>
				</Grid>
			</Grid>
		</Border>
	</Grid>
</UserControl>
