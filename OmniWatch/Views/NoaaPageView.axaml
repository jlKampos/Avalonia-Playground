<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:vm="using:OmniWatch.ViewModels"
			 xmlns:conv="clr-namespace:OmniWatch.Helpers"
			 xmlns:mapsui="clr-namespace:Mapsui.UI.Avalonia;assembly=Mapsui.UI.Avalonia"
			 xmlns:pg="clr-namespace:OmniWatch.Views.Progress"
			 xmlns:local="using:OmniWatch.Localization"
			 x:DataType="vm:NoaaPageViewModel"
			 x:Class="OmniWatch.Views.NoaaPageView">

	<UserControl.Resources>

		<DataTemplate x:Key="LightIconTemplate">
			<Label FontFamily="{DynamicResource PhosphorFill}"
				   Classes="icon"
				   Content="&#xE472;"
				   FontSize="11"
				   FontWeight="Bold"
				   Foreground="#FF191000"
				   VerticalContentAlignment="Center"
				   HorizontalContentAlignment="Center"/>
		</DataTemplate>

		<DataTemplate x:Key="DarkIconTemplate">
			<Label FontFamily="{DynamicResource PhosphorFill}"
				   Classes="icon"
				   Content="&#xE330;"
				   FontSize="11"
				   FontWeight="Bold"
				   Foreground="#FF191000"
				   VerticalContentAlignment="Center"
				   HorizontalContentAlignment="Center"/>
		</DataTemplate>

	</UserControl.Resources>

	<Grid RowDefinitions="100,*">

		<!-- HEADER -->
		<Border Grid.Row="0"
				Background="{DynamicResource ResourceKey=PanelGradient}"
				Padding="20">

			<Grid ColumnDefinitions="Auto,*,Auto"
				  VerticalAlignment="Center">

				<!-- TITLE -->
				<TextBlock Text="{Binding [Noaa_Title], Source={x:Static local:LanguageManager.Instance}}"
						   Foreground="White"
						   FontSize="20"
						   VerticalAlignment="Center"/>

				<!-- RIGHT SIDE -->
				<StackPanel Grid.Column="2"
							Orientation="Horizontal"
							HorizontalAlignment="Right"
							VerticalAlignment="Center"
							Spacing="10">

					<ComboBox ItemsSource="{Binding Years}"
							  SelectedItem="{Binding SelectedYear}"
							  Width="120"
							  VerticalAlignment="Center"/>

					<ComboBox IsEnabled="{Binding !ProgressControl.IsVisible}"
							  ItemsSource="{Binding Hurricanes}"
							  DisplayMemberBinding="{Binding Name}"
							  SelectedItem="{Binding SelectedHurricane}"
							  Width="150"
							  VerticalAlignment="Center"/>

					<Button Command="{Binding ForceRefreshCommand}"
							IsEnabled="{Binding !ProgressControl.IsVisible}"
							ToolTip.Tip="{Binding [Noaa_ClearCacheTooltip], Source={x:Static local:LanguageManager.Instance}}"
							Background="{StaticResource DarkAccent}"
							Foreground="{StaticResource DarkPrimary}"
							BorderThickness="0"
							Width="35"
							Height="35"
							Padding="0"
							HorizontalContentAlignment="Center"
							VerticalContentAlignment="Center"
							VerticalAlignment="Center">

						<TextBlock FontFamily="{DynamicResource PhosphorFill}"
								   FontSize="20"
								   Text="&#xE75A;"
								   HorizontalAlignment="Center"
								   VerticalAlignment="Center"
								   TextAlignment="Center"/>
					</Button>

				</StackPanel>

			</Grid>
		</Border>

		<!-- PROGRESS OVERLAY -->
		<Border Padding="0"
				Grid.Row="1"
				IsVisible="{Binding ProgressControl.IsVisible}"
				ZIndex="10">
			<pg:ProgressControl DataContext="{Binding ProgressControl}" />
		</Border>

		<!-- MAP BODY -->
		<Border Grid.Row="1"
				Padding="0"
				IsVisible="{Binding !ProgressControl.IsVisible}"
				Background="{DynamicResource ResourceKey=PanelGradient}">

			<Grid>

				<!-- MAP -->
				<mapsui:MapControl x:Name="MyMapControl"
								   Background="Transparent"
								   HorizontalAlignment="Stretch"
								   VerticalAlignment="Stretch"
								   Margin="0" />

				<!-- ACTIVE STORMS -->
				<Grid HorizontalAlignment="Left"
					  VerticalAlignment="Top"
					  Margin="10"
					  RowSpacing="5">

					<Border Background="#BFFFA500"
							CornerRadius="4"
							Padding="7"
							Margin="5,0,0,0"
							VerticalAlignment="Center"
							IsVisible="{Binding AnyActiveStorms}">
						<TextBlock Text="{Binding ActiveStormsMessage}"
								   Foreground="#FF191000"
								   FontSize="11"
								   FontWeight="Bold"
								   TextWrapping="Wrap"/>
					</Border>
				</Grid>

				<!-- RIGHT PANEL -->
				<Grid RowDefinitions="Auto,*"
					  HorizontalAlignment="Right"
					  VerticalAlignment="Top"
					  Margin="10"
					  RowSpacing="5">

					<!-- REANIMATE -->
					<Border Grid.Row="0"
							Background="#BF8FAA00"
							CornerRadius="4"
							Padding="6">

						<Grid ColumnDefinitions="Auto,*"
							  ColumnSpacing="10"
							  HorizontalAlignment="Stretch"
							  VerticalAlignment="Center">

							<TextBlock Text="{Binding [Noaa_Reanimate], Source={x:Static local:LanguageManager.Instance}}"
									   FontSize="11"
									   FontWeight="Bold"
									   VerticalAlignment="Center"
									   Margin="0,0,10,0"
									   Foreground="#FF191000"/>

							<ToggleSwitch Grid.Column="1"
										  Height="30"
										  Width="110"
										  IsChecked="{Binding Reanimate}"
										  HorizontalAlignment="Center"
										  VerticalAlignment="Center">

								<ToggleSwitch.OnContentTemplate>
									<DataTemplate>
										<TextBlock Text="{Binding [Noaa_Yes], Source={x:Static local:LanguageManager.Instance}}"
												   FontSize="11"
												   FontWeight="Bold"
												   HorizontalAlignment="Center"
												   VerticalAlignment="Center"
												   Foreground="#FF191000"/>
									</DataTemplate>
								</ToggleSwitch.OnContentTemplate>

								<ToggleSwitch.OffContentTemplate>
									<DataTemplate>
										<TextBlock Text="{Binding [Noaa_No], Source={x:Static local:LanguageManager.Instance}}"
												   FontSize="11"
												   FontWeight="Bold"
												   HorizontalAlignment="Center"
												   VerticalAlignment="Center"
												   Foreground="#FF191000"/>
									</DataTemplate>
								</ToggleSwitch.OffContentTemplate>

							</ToggleSwitch>

						</Grid>

					</Border>

					<!-- THEME -->
					<Border Grid.Row="1"
							Background="#BF8FAA00"
							CornerRadius="4"
							Padding="6">

						<Grid ColumnDefinitions="Auto,*"
							  ColumnSpacing="10"
							  HorizontalAlignment="Stretch"
							  VerticalAlignment="Center">

							<TextBlock Text="{Binding [Noaa_Theme], Source={x:Static local:LanguageManager.Instance}}"
									   FontSize="11"
									   FontWeight="Bold"
									   VerticalAlignment="Center"
									   Margin="0,0,10,0"
									   Foreground="#FF191000"/>

							<ToggleSwitch Grid.Column="1"
										  Width="110"
										  IsChecked="{Binding IsDarkTheme, Mode=TwoWay}"
										  HorizontalAlignment="Center"
										  VerticalAlignment="Center"
										  OffContentTemplate="{StaticResource LightIconTemplate}"
										  OnContentTemplate="{StaticResource DarkIconTemplate}" />
						</Grid>
					</Border>

				</Grid>

			</Grid>
		</Border>

	</Grid>

</UserControl>
