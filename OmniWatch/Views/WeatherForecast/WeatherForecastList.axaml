<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:OmniWatch.ViewModels"
			 xmlns:local="clr-namespace:OmniWatch.Models.IPMA.Forecast"
			 xmlns:awarness="clr-namespace:OmniWatch.Models.IPMA.Awarness"
			 mc:Ignorable="d"
			 d:DesignWidth="800"
			 d:DesignHeight="600"
			 x:Class="OmniWatch.Views.WeatherForecast.WeatherForecastList"
			 x:DataType="vm:WeatherForecastPageViewModel"
			 Background="{DynamicResource PanelGradient}">

	<Design.DataContext>
		<vm:WeatherForecastPageViewModel />
	</Design.DataContext>

	<TabControl TabStripPlacement="Left"
				Classes="modern"
				ItemsSource="{Binding Forecasts}"
				SelectedItem="{Binding SelectedTab}">

		<!-- ================= TAB HEADER ================= -->
		<TabControl.ItemTemplate>
			<DataTemplate x:DataType="local:ForecastItemDto">
				<Grid RowDefinitions="Auto,Auto"
					  ColumnDefinitions="Auto,*"
					  Margin="6">

					<!-- Icon -->
					<Svg Path="{Binding WeatherInformation.WeatherIconPath}"
						 Width="20"
						 Height="20"
						 Margin="0,0,5,0"/>

					<!-- WeekDay (localized) -->
					<TextBlock Grid.Row="0"
							   Grid.Column="1"
							   Text="{Binding LocalizedWeekDay}"
							   FontWeight="SemiBold"/>

					<!-- Date -->
					<TextBlock Grid.Row="1"
							   Grid.Column="1"
							   Text="{Binding DisplayDate}"
							   FontSize="11"
							   Opacity="0.7"/>
				</Grid>
			</DataTemplate>
		</TabControl.ItemTemplate>

		<!-- ================= CONTENT ================= -->
		<TabControl.ContentTemplate>
			<DataTemplate x:DataType="local:ForecastItemDto">

				<Border Padding="16"
						Margin="10"
						CornerRadius="12"
						Background="{DynamicResource PanelGradient}">

					<ScrollViewer VerticalScrollBarVisibility="Auto"
								  HorizontalScrollBarVisibility="Disabled"
								  AllowAutoHide="True">

						<StackPanel Spacing="16">

							<!-- ================= FORECAST ================= -->
							<StackPanel Spacing="10">

								<!-- Section Title -->
								<TextBlock Text="{x:Static vm:WeatherForecastPageViewModel.WeatherForecastTitle}"
										   FontSize="18"
										   FontWeight="SemiBold"/>

								<Border Background="{StaticResource PanelBrush}"
										Padding="15"
										CornerRadius="8">

									<StackPanel Spacing="20">

										<!-- TEMPERATURE -->
										<StackPanel Spacing="8">
											<TextBlock Text="{x:Static vm:WeatherForecastPageViewModel.TemperatureLabel}"
													   FontSize="12"
													   FontWeight="Bold"
													   Opacity="0.8"/>

											<Border Background="{StaticResource SurfaceBrush}"
													Padding="12"
													CornerRadius="8">

												<Grid ColumnDefinitions="Auto,*,Auto,*">

													<TextBlock Grid.Column="0"
															   Text="{x:Static vm:WeatherForecastPageViewModel.MinimumLabel}"
															   Opacity="0.5"
															   Margin="0,0,10,0"/>

													<TextBlock Grid.Column="1"
															   Text="{Binding TemperatureMin, StringFormat='\{0\}°C'}"
															   FontWeight="Medium"/>

													<TextBlock Grid.Column="2"
															   Text="{x:Static vm:WeatherForecastPageViewModel.MaximumLabel}"
															   Opacity="0.5"
															   Margin="20,0,10,0"/>

													<TextBlock Grid.Column="3"
															   Text="{Binding TemperatureMax, StringFormat='\{0\}°C'}"
															   FontWeight="Medium"/>
												</Grid>
											</Border>
										</StackPanel>

										<!-- WIND -->
										<StackPanel Spacing="8">
											<TextBlock Text="{x:Static vm:WeatherForecastPageViewModel.WindLabel}"
													   FontSize="12"
													   FontWeight="Bold"
													   Opacity="0.8"/>

											<Border Background="{StaticResource SurfaceBrush}"
													Padding="12"
													CornerRadius="8">

												<Grid ColumnDefinitions="Auto,*,Auto,*">

													<TextBlock Grid.Column="0"
															   Text="{x:Static vm:WeatherForecastPageViewModel.IntensityLabel}"
															   Opacity="0.5"
															   Margin="0,0,10,0"/>

													<!-- Localized wind description -->
													<TextBlock Grid.Column="1"
															   Text="{Binding LocalizedWindDescription}"/>

													<TextBlock Grid.Column="2"
															   Text="{x:Static vm:WeatherForecastPageViewModel.DirectionLabel}"
															   Opacity="0.5"
															   Margin="20,0,10,0"/>

													<TextBlock Grid.Column="3"
															   Text="{Binding PredictedWindDirection}"/>
												</Grid>
											</Border>
										</StackPanel>

										<!-- PRECIPITATION -->
										<StackPanel Spacing="8">
											<TextBlock Text="{x:Static vm:WeatherForecastPageViewModel.PrecipitationLabel}"
													   FontSize="12"
													   FontWeight="Bold"
													   Opacity="0.8"/>

											<Border Background="{StaticResource SurfaceBrush}"
													Padding="12"
													CornerRadius="8">

												<Grid ColumnDefinitions="Auto,*,Auto,*">

													<TextBlock Grid.Column="0"
															   Text="{x:Static vm:WeatherForecastPageViewModel.IntensityLabel}"
															   Opacity="0.5"
															   Margin="0,0,10,0"/>

													<!-- Localized precipitation description -->
													<TextBlock Grid.Column="1"
															   Text="{Binding LocalizedPrecipitationDescription}"/>

													<TextBlock Grid.Column="2"
															   Text="{x:Static vm:WeatherForecastPageViewModel.ProbabilityLabel}"
															   Opacity="0.5"
															   Margin="20,0,10,0"/>

													<TextBlock Grid.Column="3"
															   Text="{Binding PrecipitationProbability, StringFormat='\{0\}%'}"/>
												</Grid>
											</Border>
										</StackPanel>

									</StackPanel>
								</Border>
							</StackPanel>

							<!-- ================= AWARENESS ================= -->
							<StackPanel IsVisible="{Binding HasAwareness}"
										Spacing="10">

								<TextBlock Text="{x:Static vm:WeatherForecastPageViewModel.WarningsLabel}"
										   FontSize="16"
										   FontWeight="Bold"/>

								<ItemsControl ItemsSource="{Binding AwarnessInformation}">
									<ItemsControl.ItemTemplate>
										<DataTemplate x:DataType="awarness:AwarnessItemDto">

											<Border Padding="10"
													CornerRadius="8"
													Background="#2A2A2A"
													Margin="0,4"
													BorderThickness="0.6"
													ClipToBounds="True">

												<Grid ColumnDefinitions="6,*">

													<Rectangle Grid.Column="0"
															   Fill="{Binding LevelBrush}"
															   Width="5"
															   VerticalAlignment="Stretch"/>

													<StackPanel Grid.Column="1"
																Spacing="2"
																Margin="10,0,0,0">

														<TextBlock Text="{Binding LocalizedType}"
																   FontWeight="Bold"
																   FontSize="14"/>

														<TextBlock Text="{Binding LocalizedLevel}"
																   FontSize="12"
																   Opacity="0.9"/>

														<TextBlock Text="{Binding Period}"
																   FontSize="11"
																   Opacity="0.6"/>
													</StackPanel>
												</Grid>
											</Border>

										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>

							</StackPanel>

						</StackPanel>
					</ScrollViewer>

				</Border>

			</DataTemplate>
		</TabControl.ContentTemplate>

	</TabControl>

</UserControl>
