<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:OmniWatch.ViewModels"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
			 x:Class="OmniWatch.Views.WeatherForecast.WeatherForecastList"
			 x:DataType="vm:WeatherForecastPageViewModel"
			 xmlns:local="clr-namespace:OmniWatch.Models.Forecast"
			 xmlns:awarness="clr-namespace:OmniWatch.Models.Awarness"
			 Background="{DynamicResource ResourceKey=PanelGradient}">
	<Design.DataContext>
		<vm:WeatherForecastPageViewModel />
	</Design.DataContext>

	<TabControl TabStripPlacement="Left"
				Classes="modern"
				ItemsSource="{Binding Forecasts}"
				SelectedItem="{Binding SelectedTab}">

		<!-- ================= TAB HEADER ================= -->
		<TabControl.ItemTemplate>
			<DataTemplate x:DataType="local:ForecastItemDto">
				<Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*" Margin="6">

					<!-- Icon -->
					<Svg Path="{Binding WeatherInformation.WeatherIconPath}"
						 Width="20"
						 Height="20"
						 Margin="0,0,5,0"/>

					<!-- WeekDay -->
					<TextBlock Grid.Row="0"
							   Grid.Column="1"
							   Text="{Binding WeekDay}"
							   FontWeight="SemiBold"/>

					<!-- Date -->
					<TextBlock Grid.Row="1"
							   Grid.Column="1"
							   Text="{Binding DisplayDate}"
							   FontSize="11"
							   Opacity="0.7"/>

				</Grid>
			</DataTemplate>
		</TabControl.ItemTemplate>

		<!-- ================= CONTENT ================= -->
		<TabControl.ContentTemplate>
			<DataTemplate x:DataType="local:ForecastItemDto">

				<Border Padding="16"
						Margin="10"
						CornerRadius="12"
						Background="{DynamicResource ResourceKey=PanelGradient}">

					<ScrollViewer VerticalScrollBarVisibility="Auto"
								  HorizontalScrollBarVisibility="Disabled"
								  AllowAutoHide="True">
						<StackPanel Spacing="16">

							<!-- ================= FORECAST ================= -->
							<StackPanel Spacing="10">

								<!-- Título da Secção -->
								<TextBlock Text="Weather Forecast"
										   FontSize="18"
										   FontWeight="SemiBold"/>

								<Border Background="{StaticResource PanelBrush}" Padding="15" CornerRadius="8">
									<StackPanel Spacing="20">

										<!-- SECÇÃO: TEMPERATURA -->
										<StackPanel Spacing="8">
											<TextBlock Text="Temperature" FontSize="12" FontWeight="Bold"  Opacity="0.8"/>
											<Border Background="{StaticResource SurfaceBrush}" Padding="12" CornerRadius="8">
												<Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto">
													<TextBlock Grid.Column="0" Text="Minimum" Opacity="0.5" Margin="0,0,10,0"/>
													<TextBlock Grid.Column="1" Text="{Binding TemperatureMin, StringFormat='\{0\}°C'}" FontWeight="Medium"/>

													<TextBlock Grid.Column="2" Text="Maximum" Opacity="0.5" Margin="20,0,10,0"/>
													<TextBlock Grid.Column="3" Text="{Binding TemperatureMax, StringFormat='\{0\}°C'}" FontWeight="Medium"/>
												</Grid>
											</Border>
										</StackPanel>

										<!-- SECÇÃO: VENTO -->
										<StackPanel Spacing="8">
											<TextBlock Text="Wind" FontSize="12" FontWeight="Bold"  Opacity="0.8"/>
											<Border Background="{StaticResource SurfaceBrush}" Padding="12" CornerRadius="8">
												<Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto">
													<TextBlock Grid.Column="0" Text="Intensity" Opacity="0.5" Margin="0,0,10,0"/>
													<TextBlock Grid.Column="1" Text="{Binding WindInformation.DescriptionEN}"/>

													<TextBlock Grid.Column="2" Text="Direction" Opacity="0.5" Margin="20,0,10,0"/>
													<TextBlock Grid.Column="3" Text="{Binding PredictedWindDirection}"/>
												</Grid>
											</Border>
										</StackPanel>

										<!-- SECÇÃO: PRECIPITAÇÃO -->
										<StackPanel Spacing="8">
											<TextBlock Text="Precepitation" FontSize="12" FontWeight="Bold"  Opacity="0.8"/>
											<Border Background="{StaticResource SurfaceBrush}" Padding="12" CornerRadius="8">
												<Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto">
													<TextBlock Grid.Column="0" Text="Intensity " Opacity="0.5" Margin="0,0,10,0"/>
													<TextBlock Grid.Column="1" Text="{Binding PrecipitationInformation.DescriptionPT}"/>

													<TextBlock Grid.Column="2" Text="Probability" Opacity="0.5" Margin="20,0,10,0"/>
													<TextBlock Grid.Column="3" Text="{Binding PrecipitationProbability, StringFormat='\{0\}%'}"/>
												</Grid>
											</Border>
										</StackPanel>

									</StackPanel>
								</Border>
							</StackPanel>

							<!-- ================= AWARENESS ================= -->
							<StackPanel IsVisible="{Binding HasAwareness}" Spacing="10">

								<TextBlock Text="Warnings"
										   FontSize="16"
										   FontWeight="Bold"/>

								<ItemsControl ItemsSource="{Binding AwarnessInformation}">
									<ItemsControl.ItemTemplate>
										<DataTemplate x:DataType="awarness:AwarnessItemDto">

											<Border Padding="10"
													CornerRadius="8"
													Background="#2A2A2A"
													Margin="0,4"
													BorderThickness="0.6"
													ClipToBounds="True">
												<Grid ColumnDefinitions="6, *">
													<!-- Barra de cor lateral esquerda -->
													<Rectangle Grid.Column="0" Fill="{Binding LevelBrush}" Width="5" VerticalAlignment="Stretch"/>

													<StackPanel Grid.Column="1" Spacing="2" Margin="10,0,0,0">
														<TextBlock Text="{Binding Type}" FontWeight="Bold" FontSize="14"/>
														<TextBlock Text="{Binding DisplayLevel}" FontSize="12" Opacity="0.9"/>
														<TextBlock Text="{Binding Period}" FontSize="11" Opacity="0.6"/>
													</StackPanel>
												</Grid>
											</Border>
											<!--<Border Grid.Column="1"
											Padding="10,8"
											Background="{StaticResource PanelBrush}"
											Margin="0,4"
											ClipToBounds="True">
											<StackPanel Spacing="2">
											<TextBlock Text="{Binding Type}" FontWeight="Bold" FontSize="14"/>
											<TextBlock Text="{Binding DisplayLevel}" FontSize="12" Opacity="0.9"/>
											<TextBlock Text="{Binding Period}" FontSize="11" Opacity="0.6"/>
											</StackPanel>
											</Border>-->
											<!--<Border Padding="10"
											CornerRadius="8"
											Background="{StaticResource PanelBrush}"
											Margin="0,4"
											BorderThickness="0.6"
											ClipToBounds="True">

											<StackPanel Spacing="4">

											<Rectangle Fill="{Binding LevelBrush}" Width="6" VerticalAlignment="Stretch"/>

											<TextBlock Text="{Binding Type}"
											FontWeight="SemiBold"/>

											<TextBlock Text="{Binding DisplayLevel}"
											Opacity="0.8"/>

											<TextBlock Text="{Binding Period}"
											FontSize="12"
											Opacity="0.7"/>

											</StackPanel>

											</Border>-->
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>

							</StackPanel>

						</StackPanel>
					</ScrollViewer>

				</Border>

			</DataTemplate>
		</TabControl.ContentTemplate>

	</TabControl>

</UserControl>
