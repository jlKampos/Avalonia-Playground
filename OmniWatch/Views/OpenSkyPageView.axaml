<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:OmniWatch.ViewModels"
			 xmlns:conv="clr-namespace:OmniWatch.Helpers"
			 xmlns:mapsui="clr-namespace:Mapsui.UI.Avalonia;assembly=Mapsui.UI.Avalonia"
			 xmlns:pg="clr-namespace:OmniWatch.Views.Progress"
			 xmlns:local="using:OmniWatch.Localization"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:DataType="vm:OpenSkyPageViewModel"
			 x:Class="OmniWatch.Views.OpenSkyPageView">

	<UserControl.Resources>

		<conv:InverseBoolConverter x:Key="InverseBooleanConverter" />

		<DataTemplate x:Key="LightIconTemplate">
			<Label FontFamily="{DynamicResource PhosphorFill}"
				   Classes="icon"
				   Content="&#xE472;"
				   FontSize="11"
				   FontWeight="Bold"
				   Foreground="#FF191000"
				   VerticalContentAlignment="Center"
				   HorizontalContentAlignment="Center"/>
		</DataTemplate>

		<DataTemplate x:Key="DarkIconTemplate">
			<Label FontFamily="{DynamicResource PhosphorFill}"
				   Classes="icon"
				   Content="&#xE330;"
				   FontSize="11"
				   FontWeight="Bold"
				   Foreground="#FF191000"
				   VerticalContentAlignment="Center"
				   HorizontalContentAlignment="Center"/>
		</DataTemplate>

	</UserControl.Resources>

	<Grid RowDefinitions="100,*">

		<!-- HEADER AREA -->
		<Border Grid.Row="0" Background="{DynamicResource PanelGradient}" Padding="20">

			<Grid ColumnDefinitions="*, Auto" ColumnSpacing="20">

				<!-- LEFT SIDE -->
				<StackPanel Grid.Column="0"
							Orientation="Vertical"
							Spacing="6">

					<StackPanel Orientation="Horizontal"
								VerticalAlignment="Center"
								Spacing="10">

						<TextBlock Text="{Binding [OpenSky_Title], Source={x:Static local:LanguageManager.Instance}}"
								   Foreground="White"
								   FontSize="20"
								   VerticalAlignment="Center"/>
					</StackPanel>

					<!-- Rate‑limit information -->
					<StackPanel IsVisible="{Binding ShowRateLimitOverlay}"
								Orientation="Horizontal"
								Spacing="15">

						<!-- Remaining credits -->
						<Border Background="#338FAA00"
								CornerRadius="4"
								Padding="7"
								VerticalAlignment="Center">
							<StackPanel Orientation="Horizontal">
								<TextBlock Text="{Binding [OpenSky_RateLimitRemaining], Source={x:Static local:LanguageManager.Instance}}"
										   Foreground="{StaticResource DarkAccent}"
										   FontSize="10"/>
								<TextBlock Text="{Binding RateLimitRemaining}"
										   Margin="5,0,0,0"
										   Foreground="{StaticResource DarkAccent}"
										   FontSize="10"/>
							</StackPanel>
						</Border>

						<TextBlock Text="|" Foreground="Gray" FontSize="14" Margin="6,0"/>

						<!-- Total credits -->
						<Border Background="#338FAA00"
								CornerRadius="4"
								Padding="7"
								VerticalAlignment="Center">
							<StackPanel Orientation="Horizontal">
								<TextBlock Text="{Binding [OpenSky_RateLimitTotal], Source={x:Static local:LanguageManager.Instance}}"
										   Foreground="{StaticResource DarkAccent}"
										   FontSize="10"/>
								<TextBlock Text="{Binding RateLimitTotal}"
										   Margin="5,0,0,0"
										   Foreground="{StaticResource DarkAccent}"
										   FontSize="10"/>
							</StackPanel>
						</Border>

						<TextBlock Text="|" Foreground="Gray" FontSize="14" Margin="6,0"/>

						<!-- Update Interval -->
						<Border Background="#338FAA00"
								CornerRadius="4"
								Padding="7"
								VerticalAlignment="Center">
							<StackPanel Orientation="Horizontal">
								<TextBlock Text="{Binding [OpenSky_UpdateInterval], Source={x:Static local:LanguageManager.Instance}}"
										   Foreground="{StaticResource DarkAccent}"
										   FontSize="10"/>
								<TextBlock Text="{Binding UpdateInterval}"
										   Margin="5,0,0,0"
										   Foreground="{StaticResource DarkAccent}"
										   FontSize="10"/>
							</StackPanel>
						</Border>

						<TextBlock Text="|" Foreground="Gray" FontSize="14" Margin="6,0"/>

						<!-- Reset timestamp -->
						<Border Background="#338FAA00"
								CornerRadius="4"
								Padding="7"
								VerticalAlignment="Center">
							<StackPanel Orientation="Horizontal">
								<TextBlock Text="{Binding [OpenSky_ResetAt], Source={x:Static local:LanguageManager.Instance}}"
										   Foreground="{StaticResource DarkAccent}"
										   FontSize="10"/>
								<TextBlock Text="{Binding RateLimitResetAt}"
										   Margin="5,0,0,0"
										   Foreground="{StaticResource DarkAccent}"
										   FontSize="10"/>
							</StackPanel>
						</Border>

					</StackPanel>

				</StackPanel>

				<!-- RIGHT SIDE (empty for now) -->
				<Grid Grid.Column="1"
					  HorizontalAlignment="Right"
					  VerticalAlignment="Center"
					  RowDefinitions="Auto, Auto"
					  RowSpacing="10">
				</Grid>

			</Grid>

		</Border>

		<!-- Progress overlay -->
		<Border Padding="0" Grid.Row="1" IsVisible="{Binding ProgressControl.IsVisible}" ZIndex="10">
			<pg:ProgressControl DataContext="{Binding ProgressControl}" />
		</Border>

		<!-- MAP AREA -->
		<Border Padding="0" Grid.Row="1" IsVisible="{Binding !ProgressControl.IsVisible}">
			<Grid>

				<mapsui:MapControl x:Name="MyMapControl" />

				<!-- Warning for non-auth users -->
				<Grid HorizontalAlignment="Left"
					  VerticalAlignment="Top"
					  Margin="10">

					<Border Background="#BFFFA500"
							CornerRadius="4"
							Padding="7"
							Margin="5,0,0,0"
							IsVisible="{Binding ShowRateLimitNonAuthUser}">
						<TextBlock Text="{Binding [OpenSky_WarningRateLimit], Source={x:Static local:LanguageManager.Instance}}"
								   Foreground="#FF191000"
								   FontSize="10"
								   FontWeight="Bold"
								   TextWrapping="Wrap"/>
					</Border>
				</Grid>

				<!-- THEME -->
				<Grid HorizontalAlignment="Right"
					  VerticalAlignment="Top"
					  Margin="10">

					<Border Background="#BF8FAA00"
							CornerRadius="4"
							Padding="6">

						<Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">

							<TextBlock Text="{Binding [OpenSky_Theme], Source={x:Static local:LanguageManager.Instance}}"
									   FontSize="11"
									   FontWeight="Bold"
									   Foreground="#FF191000"/>

							<ToggleSwitch Grid.Column="1"
										  Width="110"
										  IsChecked="{Binding IsDarkTheme, Mode=TwoWay}"
										  OffContentTemplate="{StaticResource LightIconTemplate}"
										  OnContentTemplate="{StaticResource DarkIconTemplate}" />
						</Grid>
					</Border>
				</Grid>

				<!-- DATA TYPE -->
				<Grid HorizontalAlignment="Right"
					  VerticalAlignment="Bottom"
					  Margin="10">

					<Border Background="#BF8FAA00"
							CornerRadius="4"
							Padding="6">

						<Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">

							<TextBlock Text="{Binding [OpenSky_Data], Source={x:Static local:LanguageManager.Instance}}"
									   FontSize="11"
									   FontWeight="Bold"
									   Foreground="#FF191000"/>

							<ToggleSwitch Grid.Column="1"
										  Height="30"
										  Width="110"
										  IsChecked="{Binding UseRealData}">

								<ToggleSwitch.OnContentTemplate>
									<DataTemplate>
										<TextBlock Text="{Binding [OpenSky_DataReal], Source={x:Static local:LanguageManager.Instance}}"
												   FontSize="11"
												   FontWeight="Bold"
												   Foreground="#FF191000"/>
									</DataTemplate>
								</ToggleSwitch.OnContentTemplate>

								<ToggleSwitch.OffContentTemplate>
									<DataTemplate>
										<TextBlock Text="{Binding [OpenSky_DataDummy], Source={x:Static local:LanguageManager.Instance}}"
												   FontSize="11"
												   FontWeight="Bold"
												   Foreground="#FF191000"/>
									</DataTemplate>
								</ToggleSwitch.OffContentTemplate>

							</ToggleSwitch>

						</Grid>
					</Border>
				</Grid>

			</Grid>
		</Border>

	</Grid>
</UserControl>
