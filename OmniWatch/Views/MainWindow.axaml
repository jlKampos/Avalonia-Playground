<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:vm="using:OmniWatch.ViewModels"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:pg="clr-namespace:OmniWatch.Views.Progress"
		xmlns:view="clr-namespace:OmniWatch"
		xmlns:local="using:OmniWatch.Localization"
		mc:Ignorable="d"
		d:DesignWidth="1024"
		d:DesignHeight="800"
		Width="1080"
		Height="800"
		MinWidth="1080"
		MinHeight="800"
		x:Class="OmniWatch.Views.MainWindow"
		x:DataType="vm:MainWindowViewModel"
		Icon="/Assets/Images/w_icon.ico"
		Title="{Binding WindowTitle}"
		Background="{StaticResource DarkPrimary}">

	<Design.DataContext>
		<vm:MainWindowViewModel/>
	</Design.DataContext>

	<Grid Background="{DynamicResource ResourceKey=PanelGradient}"
		  ColumnDefinitions="Auto, *">

		<!-- MENU LATERAL -->
		<Border Grid.Column="0"
				Padding="20"
				Background="{DynamicResource ResourceKey=CardGradient}">
			<Grid RowDefinitions="*, Auto">

				<StackPanel Grid.Row="0" Spacing="12">

					<Image PointerPressed="Image_PointerPressed"
						   IsVisible="{Binding SideMenuExpanded}"
						   Source="{SvgImage /Assets/Images/w_logo.svg}" />

					<Image PointerPressed="Image_PointerPressed"
						   IsVisible="{Binding !SideMenuExpanded}"
						   Source="{SvgImage /Assets/Images/w_icon.svg}"
						   Width="22" />

					<!-- WEATHER -->
					<Button Classes.active="{Binding WeatherPageIsActive}"
							HorizontalAlignment="Stretch"
							Command="{Binding GoToWeatherCommand}">
						<Grid ColumnDefinitions="Auto, Auto" VerticalAlignment="Center">

							<Label Grid.Column="0"
								   FontFamily="{DynamicResource PhosphorFill}"
								   Classes="icon"
								   Content="&#xE59A;"
								   VerticalAlignment="Center"
								   Margin="0,-2,0,0" />

							<Label Grid.Column="1"
								   Content="{Binding [Main_Weather], Source={x:Static local:LanguageManager.Instance}}"
								   IsVisible="{Binding SideMenuExpanded}"
								   VerticalAlignment="Center" />
						</Grid>
					</Button>

					<!-- SEISMOLOGY -->
					<Button Classes.active="{Binding SeismologyPageIsActive}"
							HorizontalAlignment="Stretch"
							Command="{Binding GoToSeismologyCommand}">
						<Grid ColumnDefinitions="Auto, Auto" VerticalAlignment="Center">

							<Label Grid.Column="0"
								   FontFamily="{DynamicResource PhosphorFill}"
								   Classes="icon"
								   Content="&#xEAA0;"
								   VerticalAlignment="Center"
								   Margin="0,-2,0,0" />

							<Label Grid.Column="1"
								   Content="{Binding [Main_Seismology], Source={x:Static local:LanguageManager.Instance}}"
								   IsVisible="{Binding SideMenuExpanded}"
								   VerticalAlignment="Center" />
						</Grid>
					</Button>


					<!-- AIR TRAFFIC -->
					<Button Classes.active="{Binding OpenSkyPageIsActive}"
							HorizontalAlignment="Stretch"
							Command="{Binding GoToOpenSkyCommand}">
						<Grid ColumnDefinitions="Auto, Auto" VerticalAlignment="Center">

							<Label Grid.Column="0"
								   FontFamily="{DynamicResource PhosphorFill}"
								   Classes="icon"
								   Content="&#xE002;"
								   VerticalAlignment="Center"
								   Margin="0,-2,0,0" />

							<Label Grid.Column="1"
								   Content="{Binding [Main_AirTraffic], Source={x:Static local:LanguageManager.Instance}}"
								   IsVisible="{Binding SideMenuExpanded}"
								   VerticalAlignment="Center" />
						</Grid>
					</Button>


					<!-- HURRICANE CENTER -->
					<Button Classes.active="{Binding NoaaPageIsActive}"
							HorizontalAlignment="Stretch"
							Command="{Binding GoToNoaaCommand}">
						<Grid ColumnDefinitions="Auto, Auto" VerticalAlignment="Center">

							<Label Grid.Column="0"
								   FontFamily="{DynamicResource PhosphorFill}"
								   Classes="icon"
								   Content="&#xE88E;"
								   VerticalAlignment="Center"
								   Margin="0,-2,0,0" />

							<Label Grid.Column="1"
								   Content="{Binding [Main_HurricaneCenter], Source={x:Static local:LanguageManager.Instance}}"
								   IsVisible="{Binding SideMenuExpanded}"
								   VerticalAlignment="Center" />
						</Grid>
					</Button>

				</StackPanel>

				<!-- SETTINGS -->
				<Button Grid.Row="1"
						HorizontalAlignment="Stretch"
						Classes.active="{Binding SettingsPageIsActive}"
						Command="{Binding GoToSettingsCommand}">
					<Grid ColumnDefinitions="Auto, Auto" VerticalAlignment="Center">

						<Label Grid.Column="0"
							   FontFamily="{DynamicResource PhosphorFill}"
							   Classes="icon"
							   Content="&#xE270;"
							   VerticalAlignment="Center"
							   Margin="0,-2,0,0" />

						<Label Grid.Column="1"
							   Content="{Binding [Main_Settings], Source={x:Static local:LanguageManager.Instance}}"
							   IsVisible="{Binding SideMenuExpanded}"
							   VerticalAlignment="Center" />
					</Grid>
				</Button>


			</Grid>
		</Border>

		<!-- CONTENT -->
		<ContentControl Grid.Column="1" Content="{Binding CurrentPage}" />

		<!-- LOADER -->
		<Grid Grid.Column="1"
			  IsVisible="{Binding IsLoadingPage}"
			  RowDefinitions="100,*,Auto"
			  Background="{StaticResource PanelBrush}">

			<!-- HEADER -->
			<Border Grid.Row="0"
					Background="{DynamicResource ResourceKey=CardGradient}"
					Padding="0,10">
				<Border Background="{StaticResource DarkAccent}" Padding="10">

					<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
						<Label FontFamily="{StaticResource PhosphorFill}"
							   Content="&#xEE28;"
							   FontSize="20"
							   FontWeight="Bold"
							   Foreground="{StaticResource DarkPrimary}"
							   VerticalAlignment="Center"/>

						<TextBlock Text="{Binding [Main_PreparingContent], Source={x:Static local:LanguageManager.Instance}}"
								   Foreground="{StaticResource DarkPrimary}"
								   FontSize="18"
								   FontWeight="Bold"
								   VerticalAlignment="Center"/>
					</StackPanel>

				</Border>
			</Border>

			<Border Grid.Row="1" Background="{StaticResource PanelGradient}">
				<pg:ProgressControl DataContext="{Binding ProgressControl}" />
			</Border>

		</Grid>

	</Grid>

</Window>
