<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		x:Class="OmniWatch.Views.Splash.SplashWindow"
		xmlns:splash="using:OmniWatch.ViewModels.Splash"
		x:DataType="splash:SplashViewModel"
		Width="400"
		Height="250"
		WindowStartupLocation="CenterScreen"
		CanResize="False"
		SystemDecorations="None">

	<Grid HorizontalAlignment="Center" VerticalAlignment="Center">

		<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">

			<Image Source="{SvgImage /Assets/Images/w_logo.svg}" />

			<Border Background="#338FAA00"
					CornerRadius="4"
					Padding="7"
					VerticalAlignment="Center">
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
					<TextBlock Text="Loading"
							   Foreground="{StaticResource DarkAccent}"
							   FontSize="14"
							   VerticalAlignment="Center"/>

				</StackPanel>
			</Border>

		</StackPanel>

	</Grid>
</Window>