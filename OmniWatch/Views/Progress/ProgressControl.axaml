<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:OmniWatch.ViewModels.ProgressControl"
			 mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="200"
			 xmlns:ui="using:FluentAvalonia.UI.Controls"
			 x:DataType="vm:ProgressControlViewModel"
			 x:Class="OmniWatch.Views.Progress.ProgressControl"
			 Background="{DynamicResource ResourceKey=PanelGradient}">
	<Design.DataContext>
		<vm:ProgressControlViewModel/>
	</Design.DataContext>

	<StackPanel Margin="20">

		<Label Name="lnlTitle"
			   Content="{Binding Title}"
			   FontSize="24"
			   FontWeight="Bold"/>

		<StackPanel Orientation="Horizontal" Spacing="20">
			<Border Background="Transparent" Padding="20">
				<ui:ProgressRing IsIndeterminate="True"
								 BorderThickness="10"
								 Width="75"
								 Height="75"
								 Foreground="{StaticResource DarkAccent}"/>
			</Border>

			<TextBlock Name="txtContent"
					   Text="{Binding Message}"
					   FontSize="16"
					   FontWeight="SemiBold"
					   TextWrapping="Wrap"
					   MaxWidth="400"
					   HorizontalAlignment="Center"
					   VerticalAlignment="Center"/>

		</StackPanel>
	</StackPanel>
</UserControl>
