<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:settings="using:OmniWatch.ViewModels.Settings"
			 xmlns:pg="clr-namespace:OmniWatch.Views.Progress"
			 xmlns:vm="using:OmniWatch.Helpers"
			 xmlns:local="using:OmniWatch.Localization"
			 mc:Ignorable="d"
			 x:Class="OmniWatch.Views.Settings.SettingsPageView"
			 x:DataType="settings:SettingsPageViewModel">

	<UserControl.Resources>
		<vm:BoolToPasswordCharConverter x:Key="BoolToPasswordCharConverter"/>
	</UserControl.Resources>

	<Grid RowDefinitions="100,*,Auto"
		  Background="{StaticResource PanelGradient}">

		<!-- HEADER -->
		<Border Grid.Row="0" Background="{DynamicResource ResourceKey=CardGradient}" Padding="0,5">
			<Border Background="{StaticResource DarkAccent}" Padding="10">
				<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
					<Label FontFamily="{StaticResource PhosphorFill}"
						   Content="&#xE228;"
						   FontSize="20"
						   FontWeight="Bold"
						   Foreground="{StaticResource DarkPrimary}"/>

					<!-- ALTERADO: Uso da nova extensão Localize -->
					<TextBlock Text="{Binding [Settings_Title], Source={x:Static local:LanguageManager.Instance}}"
							   Foreground="{StaticResource DarkPrimary}"
							   FontSize="18"
							   FontWeight="Bold"/>

				</StackPanel>
			</Border>
		</Border>

		<!-- CONTENT -->
		<Border Grid.Row="1" Background="{StaticResource PanelGradient}" Margin="5,0,5,0" Padding="15,20">
			<Border Padding="15,20">
				<StackPanel Orientation="Vertical" Spacing="15">

					<Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto"
						  ColumnSpacing="15" RowSpacing="5">

						<!-- LANGUAGE LABEL -->
						<StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
							<Label FontFamily="{StaticResource PhosphorFill}"
								   Content="&#xE752;"
								   FontSize="20"/>
							<Label Content="{Binding [Language_Label], Source={x:Static local:LanguageManager.Instance}}" Margin="8,0"/>
						</StackPanel>

						<!-- OPEN SKY LABEL -->
						<StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
							<Label FontFamily="{StaticResource PhosphorFill}"
								   Content="&#xE752;"
								   FontSize="20"/>
							<Label Content="{Binding [UseOpenSkyCredentials_Label], Source={x:Static local:LanguageManager.Instance}}" Margin="8,0"/>
						</StackPanel>

						<!-- REFRESH LABEL -->
						<StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
							<Label FontFamily="{StaticResource PhosphorFill}"
								   Content="&#xE094;"
								   FontSize="20"/>
							<Label Content="{Binding [OpenSkyRefreshInterval_Label], Source={x:Static local:LanguageManager.Instance}}" Margin="8,0"/>
						</StackPanel>

						<ComboBox Grid.Row="1" Grid.Column="0"
								  Width="200" Height="40"
								  ItemsSource="{Binding Languages}"
								  SelectedItem="{Binding SelectedLanguage}">
							<ComboBox.ItemTemplate>
								<DataTemplate>
									<TextBlock Text="{Binding Name}" />
								</DataTemplate>
							</ComboBox.ItemTemplate>
						</ComboBox>

						<ToggleSwitch Grid.Row="1" Grid.Column="1"
									  IsChecked="{Binding UseOpenSkyCredentials, Mode=TwoWay}"
									  VerticalAlignment="Center"/>

						<NumericUpDown Grid.Row="1" Grid.Column="2"
									   ValueChanged="Numeric_ValueChanged"
									   Width="210" Height="40"
									   Minimum="1" Maximum="50"
									   Value="{Binding RefreshInterval}"
									   Increment="1"
									   FormatString="0"
									   ParsingNumberStyle="Integer"
									   ShowButtonSpinner="True"/>
					</Grid>

					<!-- CREDENTIALS SECTION -->
					<StackPanel IsVisible="{Binding UseOpenSkyCredentials}" Margin="0,10,0,0">
						<Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
							<StackPanel Grid.Row="0" Orientation="Horizontal">
								<Label FontFamily="{StaticResource PhosphorFill}"
									   Content="&#xE4C2;"
									   FontSize="20"/>
								<Label Content="{Binding [OpenSkyClientId_Label], Source={x:Static local:LanguageManager.Instance}}" Margin="8,0"/>
							</StackPanel>

							<TextBox Grid.Row="1"
									 Background="{StaticResource SurfaceBrush}"
									 Text="{Binding OpenSkyClientId}"
									 VerticalAlignment="Center"/>

							<StackPanel Grid.Row="2" Orientation="Horizontal">
								<Label FontFamily="{StaticResource PhosphorFill}"
									   Content="&#xE752;"
									   FontSize="20"/>
								<Label Content="{Binding [OpenSkyClientSecret_Label], Source={x:Static local:LanguageManager.Instance}}" Margin="8,0"/>
							</StackPanel>

							<Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="5">
								<TextBox Grid.Column="0"
										 Background="{StaticResource SurfaceBrush}"
										 Text="{Binding OpenSkyClientSecret}"
										 PasswordChar="{Binding IsSecretVisible, Converter={StaticResource BoolToPasswordCharConverter}}"
										 VerticalAlignment="Center"
										 MinWidth="200"/>

								<Button Grid.Column="1" Width="40"
										Background="{StaticResource DarkAccent}"
										Foreground="{StaticResource DarkPrimary}"
										Command="{Binding ToggleSecretVisibilityCommand}">
									<Label FontFamily="{StaticResource PhosphorFill}"
										   Content="{Binding SecretVisibilityIcon}"
										   FontSize="18"/>
								</Button>
							</Grid>
						</Grid>

						<Button Content="{Binding [TestCredentials_Button], Source={x:Static local:LanguageManager.Instance}}"
								Command="{Binding TestOpenSkyCredentialsCommand}"
								Background="{StaticResource DarkAccent}"
								Foreground="{StaticResource DarkPrimary}"
								Margin="0,10,0,0" Width="160"
								FontWeight="Bold"
								HorizontalContentAlignment="Center"/>
					</StackPanel>
				</StackPanel>
			</Border>
		</Border>

		<!-- FOOTER ACTIONS -->
		<Border Grid.Row="2" Padding="20" Background="{StaticResource PanelGradient}">
			<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
				<Button Content="{Binding [Reset_Button], Source={x:Static local:LanguageManager.Instance}}"
						Width="100"
						FontWeight="Bold"
						HorizontalContentAlignment="Center"
						Background="{StaticResource DarkAccent}"
						Foreground="{StaticResource DarkPrimary}"
						Click="OnResetClick"/>

				<Button Content="{Binding [Save_Button], Source={x:Static local:LanguageManager.Instance}}"
						Width="100"
						FontWeight="Bold"
						HorizontalContentAlignment="Center"
						Background="{StaticResource DarkAccent}"
						Foreground="{StaticResource DarkPrimary}"
						Click="OnSaveClick"/>
			</StackPanel>
		</Border>
	</Grid>
</UserControl>
