<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:OmniWatch.ViewModels"
			 xmlns:wf="clr-namespace:OmniWatch.Views.WeatherForecast"
			 xmlns:pg="clr-namespace:OmniWatch.Views.Progress"
			 xmlns:local="using:OmniWatch.Localization"
			 mc:Ignorable="d"
			 d:DesignWidth="800"
			 d:DesignHeight="450"
			 x:Class="OmniWatch.Views.WeatherForecastPageView"
			 x:DataType="vm:WeatherForecastPageViewModel">

	<Grid RowDefinitions="100,*">

		<!-- HEADER -->
		<Border Grid.Row="0"
				Background="{DynamicResource ResourceKey=PanelGradient}"
				Padding="20">

			<StackPanel Orientation="Horizontal"
						Spacing="20"
						VerticalAlignment="Center">

				<!-- TITLE -->
				<TextBlock Text="{Binding [Weather_SelectLocation], Source={x:Static local:LanguageManager.Instance}}"
						   FontSize="20"
						   Foreground="White"
						   VerticalAlignment="Center"/>

				<!-- LOCATION COMBOBOX -->
				<ComboBox Width="250"
						  ItemsSource="{Binding Locations}"
						  SelectedItem="{Binding SelectedLocation}">
					<ComboBox.ItemTemplate>
						<DataTemplate>
							<TextBlock Text="{Binding Name}" />
						</DataTemplate>
					</ComboBox.ItemTemplate>
				</ComboBox>

			</StackPanel>
		</Border>

		<!-- LOADING -->
		<Border Grid.Row="1"
				Padding="0"
				IsVisible="{Binding ProgressControl.IsVisible}">
			<pg:ProgressControl DataContext="{Binding ProgressControl}" />
		</Border>

		<!-- FORECAST LIST -->
		<Border Grid.Row="1"
				Padding="0"
				IsVisible="{Binding !ProgressControl.IsVisible}">
			<wf:WeatherForecastList />
		</Border>

	</Grid>
</UserControl>
