<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:vm="using:OmniWatch.ViewModels.MessageDialog"
		mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
		x:Class="OmniWatch.Views.MessageDialog.MessageDialogBox"
		x:DataType="vm:MessageDialogBoxViewModel"
		Width="500" SizeToContent="Height"
		CanResize="False" SystemDecorations="None"
		WindowStartupLocation="CenterOwner"
		Background="Transparent" TransparencyLevelHint="Transparent">

	<Design.DataContext>
		<vm:MessageDialogBoxViewModel/>
	</Design.DataContext>

	<Border CornerRadius="8" Background="{StaticResource PrimaryBrush}"
			BorderBrush="#444" BorderThickness="1" ClipToBounds="True">
		<Grid RowDefinitions="Auto,*,Auto" Background="{StaticResource PanelBrush}">

			<!-- HEADER DINÂMICO -->
			<Border Grid.Row="0" Background="{Binding HeaderColor}" Padding="10">
				<StackPanel Orientation="Horizontal">
					<Label FontFamily="{StaticResource PhosphorFill}"
						   Content="{Binding Icon}"
						   FontSize="20" Foreground="{StaticResource DarkPrimary}" VerticalAlignment="Center"/>
					<TextBlock Grid.Column="1" Text="{Binding Title}"
							   Foreground="{StaticResource DarkPrimary}" FontSize="16" FontWeight="Bold"
							   Margin="1,0,0,0" VerticalAlignment="Center" />
				</StackPanel>
			</Border>


			<ScrollViewer Grid.Row="1" MaxHeight="300" >
				<TextBlock Padding="15" Text="{Binding Message}"
						   TextWrapping="Wrap" FontSize="14"/>
			</ScrollViewer>

			<StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,10,10">

				<Button Content="Cancel"
						Width="100"
						Background="{Binding HeaderColor}"
						Foreground="{StaticResource DarkPrimary}"
						FontWeight="Bold"
						HorizontalContentAlignment="Center"
						Click="OnCancelClick"/>

				<Button Content="OK"
						Width="100"
						Background="{Binding HeaderColor}"
						Foreground="{StaticResource DarkPrimary}"
						FontWeight="Bold"
						HorizontalContentAlignment="Center"
						Click="OnOkClick"/>

			</StackPanel>

		</Grid>
	</Border>
</Window>
