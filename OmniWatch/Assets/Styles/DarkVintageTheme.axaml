<Styles xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="https://github.com/avaloniaui">

	<Styles.Resources>

		<!-- COLOR PALETTE -->
		<Color x:Key="DarkOrange">#33FFA500</Color>
		<Color x:Key="DarkPrimary">#1A1A1A</Color>
		<Color x:Key="DarkPanel">#262626</Color>
		<Color x:Key="DarkSurface">#333333</Color>

		<!-- Lime accent (darker) -->
		<Color x:Key="DarkAccent">#B4D400</Color>
		<!-- darker lime -->
		<Color x:Key="DarkAccentSoft">#8FAA00</Color>
		<!-- softer lime -->
		<!-- Blue accent (darker) -->
		<!--

		<Color x:Key="DarkAccent">#4FC3F7</Color>
		<Color x:Key="DarkAccentSoft">#81D4FA</Color>-->
		<Color x:Key="DarkAccentPurple">#540269</Color>
		<Color x:Key="DarkAccentOrange">#D67A1F</Color>


		<Color x:Key="DarkText">#E6E6E6</Color>
		<Color x:Key="DarkTextDim">#A0A0A0</Color>

		<!-- BRUSHES -->
		<SolidColorBrush x:Key="DarkOrangeBrush" Color="#55FFA500" />
		<SolidColorBrush x:Key="TextSelectionBrush" Color="{StaticResource DarkAccentSoft}" />
		<SolidColorBrush x:Key="TextSelectionForegroundBrush" Color="{StaticResource DarkPrimary}" />
		<SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource DarkPrimary}" />
		<SolidColorBrush x:Key="PanelBrush" Color="{StaticResource DarkPanel}" />
		<SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource DarkSurface}" />
		<SolidColorBrush x:Key="AccentBrush" Color="{StaticResource DarkAccent}" />
		<SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource DarkAccentSoft}" />
		<SolidColorBrush x:Key="TextBrush" Color="{StaticResource DarkText}" />
		<SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource DarkTextDim}" />

		<!-- ARROW FIX -->
		<SolidColorBrush x:Key="ComboBoxDropDownGlyphForeground" Color="{StaticResource DarkAccentSoft}" />

		<!-- GRADIENTS -->
		<LinearGradientBrush x:Key="PanelGradient" StartPoint="0,0" EndPoint="0,1">
			<GradientStop Color="#2A2A2A" Offset="0" />
			<GradientStop Color="#1E1E1E" Offset="1" />
		</LinearGradientBrush>

		<LinearGradientBrush x:Key="CardGradient" StartPoint="0,0" EndPoint="0,1">
			<GradientStop Color="#303030" Offset="0" />
			<GradientStop Color="#242424" Offset="0.5" />
			<GradientStop Color="#1A1A1A" Offset="1" />
		</LinearGradientBrush>

		<!-- Button normal -->
		<LinearGradientBrush x:Key="ButtonGradient" StartPoint="0,0" EndPoint="0,1">
			<GradientStop Color="#3A3A3A" Offset="0" />
			<GradientStop Color="#2A2A2A" Offset="1" />
		</LinearGradientBrush>

		<!-- Hover lime -->
		<LinearGradientBrush x:Key="ButtonHoverGradient" StartPoint="0,0" EndPoint="0,1">
			<GradientStop Color="#C6EA00" Offset="0" />
			<GradientStop Color="#A0C000" Offset="1" />
		</LinearGradientBrush>

		<!-- Pressed lime -->
		<LinearGradientBrush x:Key="ButtonPressedGradient" StartPoint="0,0" EndPoint="0,1">
			<GradientStop Color="#A8CC00" Offset="0" />
			<GradientStop Color="#7F9900" Offset="1" />
		</LinearGradientBrush>

	</Styles.Resources>


	<!-- TAB ITEM -->
	<Style Selector="TabControl.modern TabItem">
		<Setter Property="Background" Value="{StaticResource ButtonGradient}" />
		<Setter Property="CornerRadius" Value="12" />
		<Setter Property="Padding" Value="15" />
		<Setter Property="Margin" Value="8" />
		<Setter Property="BorderBrush" Value="{StaticResource DarkPanel}"/>
		<Setter Property="BorderThickness" Value="1"/>
	</Style>

	<Style Selector="TabControl.modern TabItem:pointerover">
		<Setter Property="BorderBrush" Value="{StaticResource DarkAccent}" />
		<Setter Property="Background" Value="{StaticResource DarkPanel}" />
	</Style>


	<Style Selector="TabControl.modern TabItem:selected">
		<Setter Property="BorderBrush" Value="{StaticResource DarkAccentSoft}" />
		<Setter Property="Background" Value="{StaticResource DarkPrimary}" />
	</Style>

	<Style Selector="TabControl.modern TabItem TextBlock">
		<Setter Property="FontSize" Value="15"/>
	</Style>

	<Style Selector="TabControl.modern TabItem Label.icon">
		<Setter Property="FontSize" Value="15"/>
	</Style>


	<!-- Calendar -->
	<Style Selector="Calendar">
		<Setter Property="Background" Value="{StaticResource ButtonGradient}" />
		<Setter Property="Foreground" Value="{StaticResource TextBrush}" />
		<Setter Property="CornerRadius" Value="10" />
		<Setter Property="Padding" Value="10" />
	</Style>

	<Style Selector="CalendarItem">
		<Setter Property="Background" Value="{StaticResource ButtonGradient}" />
		<Setter Property="BorderBrush" Value="{StaticResource DarkSurface}" />
		<Setter Property="BorderThickness" Value="1" />
		<Setter Property="CornerRadius" Value="10" />
		<Setter Property="Padding" Value="12" />
	</Style>

	<Style Selector="CalendarItem /template/ Button#PART_HeaderButton">
		<Setter Property="Background" Value="{StaticResource ButtonGradient}" />
		<Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
		<Setter Property="FontSize" Value="16" />
		<Setter Property="FontWeight" Value="Bold" />
		<Setter Property="CornerRadius" Value="6" />
		<Setter Property="Padding" Value="8,4" />
		<Setter Property="HorizontalAlignment" Value="Center" />
		<Setter Property="BorderBrush" Value="{StaticResource DarkSurface}" />
		<Setter Property="BorderThickness" Value="1" />
	</Style>

	<Style Selector="CalendarItem /template/ Button#PART_HeaderButton:pointerover">
		<Setter Property="Background" Value="{StaticResource DarkSurface}" />
		<Setter Property="Foreground" Value="{StaticResource AccentSoftBrush}" />
	</Style>

	<Style Selector="CalendarItem /template/ Button#PART_HeaderButton:pressed">
		<Setter Property="Background" Value="{StaticResource ButtonPressedGradient}" />
		<Setter Property="Foreground" Value="{StaticResource DarkPrimary}" />
	</Style>


	<Style Selector="CalendarButton">
		<Setter Property="Background" Value="{StaticResource ButtonGradient}" />
		<Setter Property="Foreground" Value="{StaticResource AccentSoftBrush}" />
		<Setter Property="CornerRadius" Value="6" />
		<Setter Property="Padding" Value="4" />
	</Style>

	<Style Selector="CalendarButton:pointerover">
		<Setter Property="Background" Value="{StaticResource DarkAccentSoft}" />
		<Setter Property="Foreground" Value="{StaticResource DarkPrimary}" />
	</Style>

	<Style Selector="CalendarDayButton:dayofweek">
		<Setter Property="Foreground" Value="{StaticResource TextDimBrush}" />
		<Setter Property="FontSize" Value="12" />
		<Setter Property="FontWeight" Value="SemiBold" />
		<Setter Property="Margin" Value="0,0,0,6" />
	</Style>

	<Style Selector="CalendarDayButton">
		<Setter Property="Background" Value="{StaticResource ButtonGradient}" />
		<Setter Property="Foreground" Value="{StaticResource TextBrush}" />
		<Setter Property="CornerRadius" Value="6" />
		<Setter Property="Padding" Value="6" />
		<Setter Property="BorderBrush" Value="{StaticResource DarkPrimary}" />
		<Setter Property="BorderThickness" Value="1" />
	</Style>

	<Style Selector="CalendarDayButton:pointerover">
		<Setter Property="Background" Value="{StaticResource DarkPrimary}" />
	</Style>


	<Style Selector="CalendarDayButton:today">
		<Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
		<Setter Property="BorderThickness" Value="1.2" />
	</Style>

	<Style Selector="CalendarDayButton:inactive">
		<Setter Property="Foreground" Value="{StaticResource TextDimBrush}" />
		<Setter Property="Opacity" Value="0.4" />
	</Style>

	<!-- BUTTON BASE -->
	<Style Selector="Button">
		<Setter Property="Background" Value="{StaticResource ButtonGradient}" />
		<Setter Property="Foreground" Value="{StaticResource TextBrush}" />
		<Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
		<Setter Property="BorderThickness" Value="0.1" />
		<Setter Property="Padding" Value="8,4" />
		<Setter Property="CornerRadius" Value="4" />
	</Style>

	<!-- HOVER -->
	<Style Selector="Button:pointerover">
		<Setter Property="Background" Value="{StaticResource DarkAccentSoft}" />
	</Style>

	<!-- PRESSED -->
	<Style Selector="Button:pressed">
		<Setter Property="Background" Value="{StaticResource ButtonPressedGradient}" />
	</Style>

	<!-- PRESSED TEXT FIX -->
	<Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
		<Setter Property="TextElement.Foreground" Value="Black" />
	</Style>

	<!-- ACTIVE -->
	<Style Selector="Button.active">
		<Setter Property="Background" Value="{StaticResource DarkAccentSoft}" />
		<Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
		<Setter Property="BorderThickness" Value="0.5" />
	</Style>

	<!-- ACTIVE TEXT FIX -->
	<Style Selector="Button.active Label">
		<Setter Property="FontWeight" Value="Bold" />
		<Setter Property="Foreground" Value="{StaticResource DarkPrimary}" />
	</Style>

	<Style Selector="Button.active Label.icon">
		<Setter Property="FontWeight" Value="Bold" />
		<Setter Property="Foreground" Value="{StaticResource DarkPrimary}" />
	</Style>

	<!-- ACTIVE + HOVER TEXT -->
	<Style Selector="Button.active:pointerover Label">
		<Setter Property="Foreground" Value="{StaticResource DarkAccentSoft}" />
	</Style>

	<Style Selector="Button.active:pointerover Label.icon">
		<Setter Property="Foreground" Value="{StaticResource DarkAccentSoft}" />
	</Style>


	<!-- =========================
	COMBOBOX BASE
	========================= -->

	<Style Selector="ComboBox">
		<Setter Property="Background" Value="{StaticResource ButtonGradient}" />
		<Setter Property="Foreground" Value="{StaticResource TextBrush}" />
		<Setter Property="BorderBrush" Value="{StaticResource DarkSurface}" />
		<Setter Property="BorderThickness" Value="1" />
	</Style>

	<!-- HOVER NO COMBOBOX -->
	<Style Selector="ComboBox:pointerover /template/ Border#Background">
		<Setter Property="Background" Value="{StaticResource DarkSurface}" />
		<Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
	</Style>

	<!-- =========================
	DROPDOWN (ITEMS)
	========================= -->

	<!-- ITEM BASE -->
	<Style Selector="ComboBoxItem">
		<Setter Property="Foreground" Value="{StaticResource TextBrush}" />
		<Setter Property="Background" Value="Transparent" />
	</Style>

	<!-- HOVER ITEM -->
	<Style Selector="ComboBoxItem:pointerover">
		<Setter Property="Background" Value="{StaticResource DarkAccentSoft}" />
		<Setter Property="Foreground" Value="{StaticResource DarkPrimary}" />
	</Style>

	<!-- SELECTED ITEM (IMPORTANT) -->
	<Style Selector="ComboBoxItem:selected">
		<Setter Property="Background" Value="{StaticResource AccentBrush}" />
		<Setter Property="Foreground" Value="White" />
	</Style>

	<!-- =========================
	DROPDOWN PANEL
	========================= -->
	<Style Selector="ScrollViewer ComboBoxItem">
		<Setter Property="Margin" Value="2" />
		<Setter Property="CornerRadius" Value="4" />
	</Style>
	<!--TextBox-->

	<!-- BASE -->
	<Style Selector="TextBox /template/ Border#PART_BorderElement">
		<Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
	</Style>

	<!-- HOVER -->
	<Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
		<Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
	</Style>

	<!-- FOCUS -->
	<Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
		<Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
	</Style>



	<!-- =========================
	NUMERICUPDOWN BASE
	========================= -->

	<Style Selector="NumericUpDown">
		<Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
		<Setter Property="Foreground" Value="{StaticResource TextBrush}" />
		<Setter Property="BorderBrush" Value="{StaticResource DarkSurface}" />
		<Setter Property="BorderThickness" Value="1" />
	</Style>

	<!-- HOVER (control inteiro) -->
	<Style Selector="NumericUpDown:pointerover">
		<Setter Property="BorderBrush" Value="{StaticResource AccentSoftBrush}" />
	</Style>

	<!-- =========================
	TEXTBOX INTERNO (CRÍTICO)
	========================= -->

	<!-- base -->
	<Style Selector="NumericUpDown TextBox /template/ Border#PART_BorderElement">
		<Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
		<Setter Property="BorderBrush" Value="{StaticResource DarkSurface}" />
	</Style>

	<!-- HOVER -->
	<Style Selector="NumericUpDown:pointerover TextBox /template/ Border#PART_BorderElement">
		<Setter Property="Background" Value="{StaticResource DarkSurface}" />
	</Style>

	<!-- FOCUS -->
	<Style Selector="NumericUpDown TextBox:focus /template/ Border#PART_BorderElement">
		<Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
		<Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
		<Setter Property="BorderThickness" Value="1.5" />
	</Style>

	<!-- =========================
	TEXTO (SEGURANÇA)
	========================= -->

	<Style Selector="NumericUpDown TextBox">
		<Setter Property="Foreground" Value="{StaticResource TextBrush}" />
		<Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
	</Style>

</Styles>